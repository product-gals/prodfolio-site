{
  "rewrites": [
    {
      "source": "/podcast/episodes/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|Facebot|linkedinbot|Twitterbot|Slackbot|WhatsApp|Discordbot|TelegramBot).*"
        }
      ],
      "destination": "/api/og?slug=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
